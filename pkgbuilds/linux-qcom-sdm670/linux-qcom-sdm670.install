post_upgrade() {
  if findmnt --fstab -uno SOURCE /boot &>/dev/null && ! mountpoint -q /boot; then
    echo "WARNING: /boot appears to be a separate partition but is not mounted."
  fi
}

post_remove() {
  # Clean up the specific initramfs files generated by your preset
  rm -f boot/initramfs-linux-qcom-sdm670.img
  rm -f boot/initramfs-linux-qcom-sdm670-fallback.img
}
